    <string name="consent_title">خصوصيتك مهمة</string>
    <string name="consent_intro">قبل أن تبدأ، يرجى اختيار البيانات التي ترغب بمشاركتها. يمكنك تغيير هذه في أي وقت من الإعدادات ← الخصوصية.</string>
