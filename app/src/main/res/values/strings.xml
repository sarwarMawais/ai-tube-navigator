    <string name="consent_always_on_desc">We use your location to find nearby stations, fetch live TfL data, and store your preferences on your device. None of this is shared with us.</string>
    <string name="consent_analytics">Anonymous usage analytics</string>
    <string name="consent_analytics_desc">Helps us understand which features people use so we can improve the app. No personal data, no tracking across other apps.</string>
    <string name="consent_crash">Crash reports</string>
