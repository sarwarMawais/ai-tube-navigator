<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Premium "AI Tube Navigator" icon background.
        Designed to satisfy Google Play Store launcher icon spec (Material 3,
        adaptive icon 108×108, 72×72 safe zone) and to be visually distinct
        from Transport for London's trademarked roundel/brand blue (#003688)
        to avoid Play Store IP-policy take-downs.
    -->

    <!-- Base diagonal gradient: midnight ➜ royal ➜ electric cyan glow -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0.00" android:color="#FF0A1530" />
                <item android:offset="0.45" android:color="#FF1B3FA8" />
                <item android:offset="0.85" android:color="#FF2563EB" />
                <item android:offset="1.00" android:color="#FF3DA9FC" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Top-left soft highlight for glassy depth -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="32"
                android:centerY="28"
                android:gradientRadius="60">
                <item android:offset="0.00" android:color="#33FFFFFF" />
                <item android:offset="1.00" android:color="#00FFFFFF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom-right vignette for richness -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="92"
                android:centerY="96"
                android:gradientRadius="58">
                <item android:offset="0.00" android:color="#33000000" />
                <item android:offset="1.00" android:color="#00000000" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
