<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        London Underground AI roundel — all white, works on any coloured background.
        Ring:  outer r=30 (x 24..84), inner r=20 (x 34..74), thickness=10dp
        Bar:   x 17..91, y 47..61 (h=14), stadium-capped ends
        "AI":  evenOdd cutouts — background colour shows through as letter colour
               A: outer triangle M43,61 L48,48 L53,61 + crossbar fill-back M45.5,54 L50.5,54 L50.5,56.5 L45.5,56.5
               I: rectangle M57,48 L64,48 L64,60 L57,60
    -->

    <!-- Roundel ring — bold white donut -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M84,54 A30,30 0 1 1 83.999,54 Z
            M74,54 A20,20 0 1 1 73.999,54 Z"/>

    <!-- Stadium bar with AI cutout via evenOdd -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M17,47 L91,47 Q97,47 97,54 Q97,61 91,61 L17,61 Q11,61 11,54 Q11,47 17,47 Z
            M43,61 L48,48 L53,61 Z
            M45.5,54 L50.5,54 L50.5,56.5 L45.5,56.5 Z
            M57,48 L64,48 L64,60 L57,60 Z"/>

</vector>
